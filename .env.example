VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# For "Connect Gmail" in Settings — see GMAIL_SETUP_GUIDE.md for how to get this
VITE_GOOGLE_CLIENT_ID=YOUR-GOOGLE-OAUTH-CLIENT-ID.apps.googleusercontent.com

# NOTE: the Google Client SECRET is intentionally NOT listed here.
# It must only ever be set as a Supabase Edge Function secret
# (GOOGLE_CLIENT_SECRET), never as a VITE_ variable — anything prefixed
# VITE_ gets bundled into the public frontend code that anyone can read.
# See GMAIL_SETUP_GUIDE.md Step 6.
